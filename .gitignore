# Photos are personal — every user supplies their own (see README).
# The folder is kept (via .gitkeep) but its contents are never committed.
contents/photos/*
!contents/photos/.gitkeep

# Generated preview of the layouts — reflects whoever's photo library it was
# built against, so it is not the same file for two people.
.layouts-preview.html

# Backups / archives
*.tar.gz
*.zip

# Tooling / editor / OS cruft
.claude/
*.swp
*~
.DS_Store
